generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["we-crm"]
}

// ── Better Auth tables ─────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String?
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]

  contacts       Contact[]
  contactLists   ContactList[]
  emailCampaigns EmailCampaign[]
  flows          Flow[]

  members         Member[]
  invitationsSent Invitation[] @relation("invitations_sent")

  @@unique([email])
  @@map("user")
  @@schema("we-crm")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy       String?
  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
  @@schema("we-crm")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
  @@schema("we-crm")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
  @@schema("we-crm")
}

// ── Organization tables ────────────────────────────────────────────

model Organization {
  id        String   @id
  name      String
  slug      String?
  logo      String?
  createdAt DateTime @default(now())
  metadata  String?

  members     Member[]
  invitations Invitation[]

  contacts       Contact[]
  contactLists   ContactList[]
  emailCampaigns EmailCampaign[]
  flows          Flow[]

  @@map("organization")
  @@schema("we-crm")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  createdAt      DateTime     @default(now())

  @@map("member")
  @@schema("we-crm")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  inviter        User         @relation("invitations_sent", fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitation")
  @@schema("we-crm")
}

// ── CRM tables ─────────────────────────────────────────────────────

model Contact {
  id        String   @id
  firstName String
  lastName  String?
  email     String?
  phone     String?
  company   String?
  jobTitle  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unsubscribedAt    DateTime?
  unsubscribeReason UnsubscribeReason?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  listEntries     ContactListEntry[]
  campaignEmails  EmailCampaignContact[]
  flowEnrollments FlowEnrollment[]
  agentLeadLinks AgentLeadContact[]

  @@map("contact")
  @@schema("we-crm")
}

enum UnsubscribeReason {
  NOT_INTERESTED
  TOO_FREQUENT
  NEVER_SUBSCRIBED
  NOT_RELEVANT
  OTHER

  @@schema("we-crm")
}

model ContactList {
  id          String   @id
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  entries        ContactListEntry[]
  emailCampaigns EmailCampaign[]

  @@map("contact_list")
  @@schema("we-crm")
}

model ContactListEntry {
  id            String      @id
  contactListId String
  contactList   ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  contactId     String
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  addedAt       DateTime    @default(now())

  @@unique([contactListId, contactId])
  @@map("contact_list_entry")
  @@schema("we-crm")
}

// ── Email Campaign tables ──────────────────────────────────────────

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED

  @@schema("we-crm")
}

enum EmailSendStatus {
  PENDING
  SENT
  FAILED
  BOUNCED

  @@schema("we-crm")
}

model EmailCampaign {
  id          String              @id
  name        String
  subject     String
  htmlContent String
  status      EmailCampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  contactListId String
  contactList   ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  recipients EmailCampaignContact[]

  @@map("email_campaign")
  @@schema("we-crm")
}

model EmailCampaignContact {
  id              String          @id
  emailCampaignId String
  emailCampaign   EmailCampaign   @relation(fields: [emailCampaignId], references: [id], onDelete: Cascade)
  contactId       String
  contact         Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status          EmailSendStatus @default(PENDING)
  sentAt          DateTime?
  errorMessage    String?
  createdAt       DateTime        @default(now())

  @@unique([emailCampaignId, contactId])
  @@map("email_campaign_contact")
  @@schema("we-crm")
}

// ── Flow tables ────────────────────────────────────────────────────────────

enum FlowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
  FAILED

  @@schema("we-crm")
}

enum FlowNodeType {
  LIST_SOURCE
  SEND_EMAIL
  WAIT

  @@schema("we-crm")
}

enum FlowEnrollmentStatus {
  ACTIVE
  COMPLETED
  FAILED

  @@schema("we-crm")
}

model Flow {
  id        String     @id
  name      String
  status    FlowStatus @default(DRAFT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  nodes       FlowNode[]
  edges       FlowEdge[]
  enrollments FlowEnrollment[]

  @@map("flow")
  @@schema("we-crm")
}

model FlowNode {
  id     String       @id
  flowId String
  flow   Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  type   FlowNodeType
  config Json
  posX   Float
  posY   Float

  outEdges    FlowEdge[]       @relation("edge_source")
  inEdges     FlowEdge[]       @relation("edge_target")
  enrollments FlowEnrollment[]

  @@map("flow_node")
  @@schema("we-crm")
}

model FlowEdge {
  id           String   @id
  flowId       String
  flow         Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  sourceNodeId String
  sourceNode   FlowNode @relation("edge_source", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNodeId String
  targetNode   FlowNode @relation("edge_target", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@map("flow_edge")
  @@schema("we-crm")
}

model FlowEnrollment {
  id            String               @id
  flowId        String
  flow          Flow                 @relation(fields: [flowId], references: [id], onDelete: Cascade)
  contactId     String
  contact       Contact              @relation(fields: [contactId], references: [id], onDelete: Cascade)
  currentNodeId String?
  currentNode   FlowNode?            @relation(fields: [currentNodeId], references: [id])
  status        FlowEnrollmentStatus @default(ACTIVE)
  nextActionAt  DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([flowId, contactId])
  @@map("flow_enrollment")
  @@schema("we-crm")
}

// ── Lead Agent tables ──────────────────────────────────────────────

model EnrichmentJob {
  id                  String    @id
  jobName             String?
  status              String
  progress            Float?
  icpJson             Json?
  icpRaw              String?
  error               String?
  currentFunnelStage  String?
  stageCounts         Json?
  metricsJson         Json?
  createdAt           DateTime  @default(now())
  finishedAt          DateTime?
  updatedAt           DateTime  @updatedAt

  companies          LeadCompany[]
  leads              AgentLead[]
  leadContacts       AgentLeadContact[]
  funnelStageEvents  FunnelStageEvent[]
  evidenceRecords    EvidenceRecord[]

  @@map("enrichment_job")
  @@schema("we-crm")
}

model LeadCompany {
  id            Int           @id @default(autoincrement())
  jobId         String
  job           EnrichmentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name          String?
  domain        String?
  website       String?
  sector        String?
  icpFitScore   Float?
  disqualified  Boolean       @default(false)
  linkedinUrl   String?
  instagram     String?
  facebook      String?
  email         String?
  phone         String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  domainAgeDays Int?
  technologies  String[]      @default([])
  source        String?
  profileJson   Json?
  enrichedAt    DateTime?

  leads         AgentLead[]

  @@index([jobId])
  @@index([domain])
  @@unique([jobId, id])
  @@map("lead_company")
  @@schema("we-crm")
}

model AgentLead {
  id               Int           @id @default(autoincrement())
  jobId            String
  job              EnrichmentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  companyId        Int?
  company          LeadCompany?  @relation(fields: [jobId, companyId], references: [jobId, id])
  fullName         String?
  role             String?
  email            String?
  emailConfidence  Float?
  emailVerified    Boolean?
  phone            String?
  linkedinUrl      String?
  instagram        String?
  outreachStatus   String        @default("pending")
  outreachAngle    String?
  score            Float?
  scoreReason      String?
  bantJson         Json?
  redFlags         String[]       @default([])
  emailSubject     String?
  emailBody        String?
  followUp1        String?
  followUp2        String?
  hubspotContactId String?
  leadJson         Json?
  discoveredAt     DateTime?
  contactLinks     AgentLeadContact[]

  @@index([jobId])
  @@index([companyId])
  @@index([email])
  @@index([linkedinUrl])
  @@unique([jobId, id])
  @@map("agent_lead")
  @@schema("we-crm")
}

model AgentLeadContact {
  id          Int           @id @default(autoincrement())
  jobId       String
  job         EnrichmentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  agentLeadId Int
  agentLead   AgentLead     @relation(fields: [jobId, agentLeadId], references: [jobId, id], onDelete: Cascade)
  contactId   String
  contact     Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  matchedBy   String[]      @default([])
  createdAt   DateTime      @default(now())

  @@unique([agentLeadId, contactId])
  @@index([jobId])
  @@index([agentLeadId])
  @@index([contactId])
  @@map("agent_lead_contact")
  @@schema("we-crm")
}

model FunnelStageEvent {
  id           Int          @id @default(autoincrement())
  jobId        String
  job          EnrichmentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stage        String?
  eventType    String?
  entityType   String?
  entityKey    String?
  reasonCode   String?
  reasonDetail String?
  createdAt    DateTime     @default(now())

  @@index([jobId])
  @@map("funnel_stage_event")
  @@schema("we-crm")
}

model EvidenceRecord {
  id          Int          @id @default(autoincrement())
  jobId       String
  job         EnrichmentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  entityType  String?
  entityKey   String?
  sourceUrl   String?
  title       String?
  snippet     String?
  signalType  String?
  confidence  Float?
  capturedAt  DateTime?

  @@index([jobId])
  @@map("evidence_record")
  @@schema("we-crm")
}
